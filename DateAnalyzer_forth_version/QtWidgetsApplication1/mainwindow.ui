  <property name="styleSheet">
   <string notr="true">/* 1. 设置全局底色（清新淡雅灰） */
QMainWindow {
    background-color: #f2f2f2;
}

/* 2. 给多页面容器设置水印，使其在每一页的正中央显示 */
#mainStackedWidget {
    background-image: url(:/new/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
}

/* 3. 让页面背景透明，确保能看到底层的校徽 */
#mainStackedWidget &gt; QWidget {
    background: transparent;
}

/* 4. 按钮精修：白底 + 南开紫线条 */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #741B47;  /* 南开紫标准色 */
    border-radius: 6px;
    color: #741B47;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 16px;
    font-weight: bold;
    min-height: 55px; /* 让按钮看起来厚实些 */
}

/* 按钮鼠标悬停效果：变色反转 */
QPushButton:hover {
    background-color: #741B47;
    color: #ffffff;
}

/* 5. 表格、输入框、文本框：半透明白（若隐若现看到水印） */
QTableWidget, QLineEdit, QTextEdit {
    background-color: rgba(255, 255, 255, 150); /* 150/255 的透明度 */
    border: 1px solid #d1d1d1;
    border-radius: 4px;
    color: #333333;
}

/* 6. 防止水印在按钮或小零件内部重复出现 */
QPushButton, QLineEdit, QHeaderView, QLabel {
    background-image: none;
}
#centralWidget {
    background-color: #fdfaf2; /* 象牙暖米色 */
    background-image: url(:/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
}
QPushButton {
    /* 使用 rgba，最后的 150 表示背景只有约 60% 的不透明度 */
    background-color: rgba(255, 255, 255, 150); 
    border: 1px solid #741B47;
    border-radius: 8px;
    color: #741B47;
    font-weight: bold;
}

QPushButton:hover {
    /* 悬停时稍微加深透明度，产生交互感 */
    background-color: rgba(116, 27, 71, 40); 
}</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <property name="styleSheet">
    <string notr="true">#centralWidget {
    background-color: #f4f4f9; /* 极淡的紫灰色，干净且有质感 */
    background-image: url(:/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
}
/* 1. 按钮的常态：带有质感的南开紫 */
QPushButton {
    /* 渐变底色：让按钮看起来有立体感 */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
                      stop:0 rgba(255, 255, 255, 255), 
                      stop:1 rgba(240, 230, 245, 255));
    
    border: 2px solid #741B47;       /* 南开紫边框 */
    border-radius: 12px;             /* 大圆角，更有游戏UI感 */
    color: #741B47;                  /* 文字颜色 */
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
    min-height: 55px;
}

/* 2. 鼠标悬停态：产生“发光”效果 */
QPushButton:hover {
    /* 背景变亮 */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
                      stop:0 rgba(116, 27, 71, 20), 
                      stop:1 rgba(116, 27, 71, 50));
    
    /* 边框变为亮紫色（霓虹光） */
    border: 2px solid #a000ff;       
    color: #a000ff;                  /* 文字也跟着亮起来 */
    
    /* 模拟外发光：增加边框厚度感 */
    padding-left: 11px;
    padding-top: 11px;
}

/* 3. 按钮按下态：反馈效果 */
QPushButton:pressed {
    background-color: #741B47;       /* 按下时背景填满南开紫 */
    border: 2px solid #00f0ff;       /* 边框闪烁青色光芒（赛博点缀） */
    color: white;                    /* 文字反白 */
}
QPushButton, QLabel, QLineEdit, QTableWidget {
    background-image: none;
}</string>
