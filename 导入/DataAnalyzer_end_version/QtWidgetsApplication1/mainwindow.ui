  <property name="styleSheet">
   <string notr="true">/* 1. 设置全局底色（清新淡雅灰） */
QMainWindow {
    background-color: #f2f2f2;
}

/* 2. 给多页面容器设置水印，使其在每一页的正中央显示 */
#mainStackedWidget {
    background-image: url(:/new/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
}

/* 3. 让页面背景透明，确保能看到底层的校徽 */
#mainStackedWidget &gt; QWidget {
    background: transparent;
}

/* 4. 按钮精修：白底 + 南开紫线条 */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #741B47;  /* 南开紫标准色 */
    border-radius: 6px;
    color: #741B47;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 16px;
    font-weight: bold;
    min-height: 55px; /* 让按钮看起来厚实些 */
}

/* 按钮鼠标悬停效果：变色反转 */
QPushButton:hover {
    background-color: #741B47;
    color: #ffffff;
}

/* 5. 表格、输入框、文本框：半透明白（若隐若现看到水印） */
QTableWidget, QLineEdit, QTextEdit {
    background-color: rgba(255, 255, 255, 150); /* 150/255 的透明度 */
    border: 1px solid #d1d1d1;
    border-radius: 4px;
    color: #333333;
}

/* 6. 防止水印在按钮或小零件内部重复出现 */
QPushButton, QLineEdit, QHeaderView, QLabel {
    background-image: none;
}
#centralWidget {
    background-color: #fdfaf2; /* 象牙暖米色 */
    background-image: url(:/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
}
QPushButton {
    /* 使用 rgba，最后的 150 表示背景只有约 60% 的不透明度 */
    background-color: rgba(255, 255, 255, 150); 
    border: 1px solid #741B47;
    border-radius: 8px;
    color: #741B47;
    font-weight: bold;
}

QPushButton:hover {
    /* 悬停时稍微加深透明度，产生交互感 */
    background-color: rgba(116, 27, 71, 40); 
}
QLabel#label_question {
    font-family: &quot;楷体&quot;, &quot;KaiTi&quot; !important;
    font-size: 45px !important;       /* 增加到 45px，保证你能看出变化 */
    color: #741B47 !important;
    background-color: transparent !important;
    min-height: 80px;                 /* 必须给高度，否则字会被切掉 */
}

/* 2. 强力定位：只针对叫 edit_answer 的 QLineEdit */
QLineEdit#edit_answer {
    background-color: rgba(255, 255, 255, 150) !important; 
    border: 2px solid #741B47 !important;
    border-radius: 10px;
    font-size: 20px;
    min-height: 45px;
}</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <property name="styleSheet">
    <string notr="true">#centralWidget {
    background-color: #f4f4f9; /* 极淡的紫灰色，干净且有质感 */
    background-image: url(:/images/nankai_watermark.png);
    background-repeat: no-repeat;
    background-position: center;
}
/* 1. 按钮的常态：带有质感的南开紫 */
QPushButton {
    background-color: #ffffff !important; 
    color: #741B47 !important; /* 南开紫 */
    
    /* 修正字体写法：使用标准的 font 简写属性，兼容性更好 */
    font: 24px &quot;STXingkai&quot;, &quot;华文行书&quot;, &quot;KaiTi&quot;, &quot;楷体&quot;;
    
    border: 2px solid #741B47 !important;
    border-radius: 25px;
    min-height: 50px;
    padding: 5px 20px;
}

/* 按钮发光态 */
QPushButton:hover {
    color: #a000ff !important; /* 字体变为亮紫色 */
    border: 2px solid #a000ff !important; /* 边框变为亮紫色 */
    /* 增加一个淡淡的紫色背景，模拟发光感 */
    background-color: rgba(160, 0, 255, 15) !important;
}

/* 4. 【标签精修】 */
QLabel {
    background-color: transparent !important;
    color: #741B47 !important;
    font: bold 20px &quot;STXingkai&quot;, &quot;华文行书&quot;, &quot;楷体&quot;;
}

/* 5. 【防止零件内部出现校徽】 */
QPushButton, QLineEdit, QTableWidget, QTextEdit, QHeaderView {
    background-image: none !important;
}
</string>
